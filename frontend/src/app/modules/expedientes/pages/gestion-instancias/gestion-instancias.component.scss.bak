           border-bottom: 1px solid #e5e7eb;
           transition: background 0.15s;
           
           &:hover {
             background: #f9fafb;
           }
           
           &.expediente-row {
             background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
             
             &:hover {
               background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
             }
           }
           
           &.state-activo {
             background: rgba(34, 197, 94, 0.02);
           }
           
