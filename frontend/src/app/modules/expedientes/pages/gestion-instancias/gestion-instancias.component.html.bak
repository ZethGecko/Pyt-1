<div class="gestion-instancias-container">
  <!-- Header -->
  <div class="page-header">
    <div class="header-content">
      <h1>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="w-8 h-8">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
        </svg>
        Gestión de Expedientes
      </h1>
    </div>
    
    <!-- Filtros -->
    <div class="filters-bar">
      <div class="filter-group">
        <input type="text" 
               placeholder="Buscar por RUT..." 
               [(ngModel)]="filtroRut"
               class="filter-input">
      </div>
      <div class="filter-group">
        <input type="text" 
               placeholder="Trámite ID..." 
               [(ngModel)]="filtroTramiteId"
               class="filter-input">
      </div>
      <button class="btn btn-secondary" (click)="limpiarFiltros()">Limpiar</button>
    </div>
  </div>

  <!-- Modal de Revisión de Requisitos -->
  @if (mostrarRevision) {
    <app-revision-requisitos
      [tramiteId]="tramiteParaRevision"
      [tramiteCodigoRUT]="tramiteCodigoRUT"
      [tramiteTipoDescripcion]="tramiteTipoDescripcion"
      [instanciaId]="instanciaParaRevision"
      (cerrarModal)="cerrarRevision()"
      (tramiteObservado)="onTramiteObservado()"
      (tramiteFinalizado)="onTramiteFinalizado()">
    </app-revision-requisitos>
  }

  <!-- Mensajes -->
  @if (error) {
    <div class="alert alert-error">
      {{ error }}
      <button (click)="limpiarMensajes()">×</button>
    </div>
  }
  
  @if (exito) {
    <div class="alert alert-success">
      {{ exito }}
      <button (click)="limpiarMensajes()">×</button>
    </div>
  }

  <!-- Tabla de Expedientes (Agrupados por RUT) -->
  <div class="table-container">
    <table class="data-table">
      <thead>
         <tr>
           <th>Expediente (RUT)</th>
           <th>Tipo Trámite</th>
           <th># Instancias</th>
           <th>Fecha Primera Instancia</th>
           <th>Última Actividad</th>
           <th>Acciones</th>
         </tr>
      </thead>
      <tbody>
        @if (cargando) {
          <tr>
            <td colspan="6" class="loading-cell">
              <div class="spinner"></div>
              <span>Cargando expedientes...</span>
            </td>
          </tr>
        } @else if (expedientesFiltrados.length === 0) {
          <tr>
            <td colspan="6" class="empty-cell">
              <div class="empty-state">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                <p>No se encontraron expedientes</p>
              </div>
            </td>
          </tr>
        } @else {
          @for (exp of expedientesFiltrados; track exp.rut) {
            <tr class="expediente-row">
              <td>
                <div class="rut-cell">
                  <strong>{{ exp.rut }}</strong>
                </div>
              </td>
               <td>{{ exp.tipoTramiteDescripcion || '—' }}</td>
              <td>
                <span class="badge badge-info">{{ exp.instancias.length }} vehículo(s)</span>
              </td>
               <td>
                 @if (exp.instancias.length > 0) {
                   {{ exp.instancias[0].fechaActualizacion | date:'dd/MM/yyyy' }}
                 } @else { — }
               </td>
              <td>
                @if (exp.instancias.length > 0) {
                  @for (inst of exp.instancias; track inst.idInstancia) {
                    <div class="last-activity">
                      {{ inst.identificador }}: {{ inst.fechaCreacion | date:'dd/MM/yyyy HH:mm' }}
                    </div>
                  }
                } @else { — }
              </td>
              <td>
                <div class="action-buttons">
                  <button class="btn-action btn-view" (click)="abrirModalInstancias(exp)" title="Ver instancias del expediente">
                    📦 Ver Instancias
                  </button>
                </div>
              </td>
            </tr>
          }
        }
      </tbody>
    </table>
  </div>

  <!-- 🎯 MODAL DE GESTIÓN DE INSTANCIAS POR EXPEDIENTE -->
  @if (mostrandoModalInstancias && expedienteSeleccionado) {
    <div class="modal-overlay" (click)="cerrarModalInstancias()">
      <div class="modal-content modal-lg" (click)="$event.stopPropagation()">
        <div class="modal-header">
          <h2>
            📦 Expediente: {{ expedienteSeleccionado.rut }}
            <span class="badge badge-info">{{ expedienteSeleccionado.instancias.length }} vehículo(s)</span>
          </h2>
          <button class="modal-close" (click)="cerrarModalInstancias()">×</button>
        </div>
        
        <div class="modal-body">
          <!-- Botón Añadir Instancia -->
          <div class="add-instance-bar">
            <button class="btn btn-primary" (click)="abrirPromptNuevaInstancia()" [disabled]="cargando">
              + Añadir Nueva Instancia
            </button>
            <p class="add-instance-hint">
              Cree una nueva instancia (vehículo) para este expediente
            </p>
          </div>

          <!-- Tabla de instancias del expediente -->
          <div class="table-container" style="margin-top: 1rem;">
            <table class="data-table">
               <thead>
                 <tr>
                   <th>ID</th>
                   <th>Identificador</th>
                   <th>Estado</th>
                   <th>Fecha Creación</th>
                   <th>Acciones</th>
                 </tr>
               </thead>
              <tbody>
                 @if (expedienteSeleccionado.instancias.length === 0) {
                   <tr>
                     <td colspan="5" class="empty-cell">
                       <div class="empty-state">
                         <p>No hay instancias en este expediente</p>
                         <p class="text-sm">Haga clic en "Añadir Nueva Instancia" para crear la primera</p>
                       </div>
                     </td>
                   </tr>
                } @else {
                  @for (inst of expedienteSeleccionado.instancias; track inst.idInstancia) {
                     <tr [class]="'state-' + (inst.estado?.toLowerCase() || '')">
                       <td><strong>{{ inst.idInstancia }}</strong></td>
                       <td>
                         <div class="identifier-cell">
                           <strong>{{ inst.identificador }}</strong>
                         </div>
                       </td>
                       <td>
                         <span class="badge" [class]="getColorEstado(inst.estado)">
                           {{ getEstadoFormateado(inst.estado) }}
                         </span>
                       </td>
                        <td>{{ (inst.fechaActualizacion || inst.fechaCreacion) | date:'dd/MM/yyyy HH:mm' }}</td>
                       <td>
                        <div class="action-buttons">
                          <button class="btn-action btn-edit" (click)="abrirModalEdicion(inst)" title="Editar instancia">
                            ✏️ Editar
                          </button>
                          <button class="btn-action btn-delete" (click)="eliminarInstancia(inst)" title="Eliminar">
                            🗑️ Eliminar
                          </button>
                        </div>
                      </td>
                    </tr>
                  }
                }
              </tbody>
            </table>
          </div>
        </div>
        
        <div class="modal-footer">
          <button class="btn btn-outline" (click)="cerrarModalInstancias()">Cerrar</button>
        </div>
      </div>
    </div>
  }

  <!-- 🎯 MODAL DE EDICIÓN DE INSTANCIA -->
  @if (mostrandoModalEdicion && instanciaEditando) {
    <div class="modal-overlay" (click)="cerrarModalEdicion()">
      <div class="modal-content" (click)="$event.stopPropagation()">
        <div class="modal-header">
          <h2>✏️ Editar Instancia</h2>
          <button class="modal-close" (click)="cerrarModalEdicion()">×</button>
        </div>
        <div class="modal-body">
          <form #form="ngForm">
            <div class="form-group">
              <label>Identificador (Placa) *</label>
              <input type="text" 
                     [(ngModel)]="formInstancia.identificador" 
                     name="identificador"
                     class="form-control"
                     placeholder="Ej: ABC-123">
              @if (!formInstancia.identificador) {
                <small class="error-msg">Campo obligatorio</small>
              }
            </div>
            
            <div class="form-group">
              <label>Estado</label>
              <select [(ngModel)]="formInstancia.estado" name="estado" class="form-control">
                @for (est of estadosInstancia; track est.value) {
                  <option [value]="est.value">{{ est.label }}</option>
                }
              </select>
            </div>
           </form>
           
           <!-- Sección de Calificación de Requisitos -->
          @if (documentosInstancia.length > 0) {
            <div class="requisitos-edicion">
              <h4 class="section-title">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="w-4 h-4">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                Calificación de Requisitos
              </h4>
              <div class="table-container" style="max-height: 300px; overflow-y: auto;">
                <table class="data-table">
                  <thead>
                    <tr>
                      <th>Requisito</th>
                      <th style="width: 180px;">Estado</th>
                      <th>Observaciones</th>
                    </tr>
                  </thead>
                  <tbody>
                    @for (doc of documentosInstancia; track doc.id) {
                      <tr>
                         <td>
                           <div class="requisito-info">
                             <strong>{{ doc.requisito?.descripcion || 'Requisito ' + doc.requisitoId }}</strong>
                             @if (doc.requisito?.codigo) {
                               <small class="requisito-codigo">{{ doc.requisito.codigo }}</small>
                             }
                           </div>
                         </td>
                        <td>
                          <select [(ngModel)]="doc.estado" class="form-control form-control-sm">
                            <option value="APROBADO">Aprobado</option>
                            <option value="DESAPROBADO">Desaprobado</option>
                            <option value="OBSERVADO">Observado</option>
                          </select>
                        </td>
                        <td>
                          <input type="text" class="form-control form-control-sm" [(ngModel)]="doc.observaciones" placeholder="Observaciones">
                        </td>
                      </tr>
                    }
                  </tbody>
                </table>
              </div>
            </div>
          }
        </div>
        <div class="modal-footer">
          <button class="btn btn-outline" (click)="cerrarModalEdicion()">Cancelar</button>
          <button class="btn btn-primary" (click)="guardarEdicionInstancia()" [disabled]="cargando">
            💾 Guardar Cambios
          </button>
        </div>
      </div>
    </div>
  }

  <!-- 🎯 MODAL PROMPT PARA NUEVA INSTANCIA (Estilizado) -->
  @if (mostrarPromptNuevaInstancia) {
    <div class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 animate-fade-in">
      <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4 overflow-hidden">
        <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-6 py-4">
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h3 class="text-lg font-semibold text-white">Nueva Instancia</h3>
          </div>
        </div>
        
        <div class="px-6 py-6">
          <p class="text-gray-700 mb-4">
            Ingrese identificador del vehículo (placa):
          </p>
          <input type="text"
                 class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition text-lg"
                 [(ngModel)]="nuevoIdentificadorInstancia"
                 placeholder="Ej: ABC-123"
                 (keyup.enter)="aceptarPromptNuevaInstancia()"
                 autofocus>
          <p class="text-xs text-gray-500 mt-2">
            Este vehículo se asociará al expediente <strong>{{ expedienteSeleccionado?.rut }}</strong>
          </p>
        </div>
        
        <div class="bg-gray-50 px-6 py-4 flex justify-end gap-3">
          <button type="button"
                  class="px-5 py-2 text-gray-600 hover:text-gray-800 font-medium transition"
                  (click)="cancelarPromptNuevaInstancia()">
            Cancelar
          </button>
          <button type="button"
                  class="px-5 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 font-medium transition shadow-md"
                  (click)="aceptarPromptNuevaInstancia()">
            Crear Instancia
          </button>
        </div>
      </div>
    </div>
  }
</div>
␀␀␀␀␀␀␀␀␀␀␀␀␀